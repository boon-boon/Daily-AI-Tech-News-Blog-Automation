# =============================================================================
# Daily AI Tech News Blog - Environment Configuration
# Copy this file to .env and fill in real credentials.
# =============================================================================

# ----------------------------- LLM (Google Gemini) ---------------------------
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-your-google-ai-studio-api-key-here

# Recommended models (cheap -> premium):
#   gemini-2.5-flash-lite       (cheapest, fastest)
#   gemini-2.5-flash            (default — great cost / quality balance)
#   gemini-2.5-pro              (highest quality, slower, more expensive)
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_MAX_TOKENS=4000
GEMINI_TEMPERATURE=0.4

# ----------------------------- Blog Identity ---------------------------------
BLOG_NAME=Daily Tech Pulse
BLOG_AUTHOR=Daily Tech Pulse Editorial
BLOG_BASE_URL=
BLOG_LANGUAGE=en
BLOG_DEFAULT_CATEGORY=Technology

# ----------------------------- Scheduler -------------------------------------
# 24-hour format, Malaysia time (Asia/Kuala_Lumpur)
RUN_TIME=08:00
TIMEZONE=Asia/Kuala_Lumpur
# If true, runs in long-lived scheduler mode; otherwise runs once and exits.
SCHEDULER_MODE=cron

# ----------------------------- News Sources ----------------------------------
# Optional API keys
NEWSAPI_KEY=
GITHUB_TOKEN=
HUGGINGFACE_TOKEN=

# Comma-separated list of GitHub trending languages to monitor
GITHUB_TRENDING_LANGUAGES=python,javascript,typescript,rust,go

# Comma-separated list of GitHub repositories to track for releases
GITHUB_TRACKED_REPOS=angular/angular,facebook/react,vuejs/core,python/cpython,nodejs/node,microsoft/TypeScript,vercel/next.js,sveltejs/svelte

# Lookback window in hours
LOOKBACK_HOURS=24

# Minimum number of items to keep after filtering
MIN_ITEMS=5
MAX_ITEMS=12

# ----------------------------- Article Strategy ------------------------------
# either 'individual' (one article per item) or 'digest' (single rollup)
ARTICLE_MODE=individual

# ----------------------------- Output ----------------------------------------
OUTPUT_DIR=./output
LOG_DIR=./logs
LOG_LEVEL=INFO

# ----------------------------- WordPress (optional) --------------------------
PUBLISH_TO_WORDPRESS=false
WORDPRESS_URL=https://yourblog.com
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
WORDPRESS_DEFAULT_STATUS=draft
WORDPRESS_DEFAULT_CATEGORY_ID=
